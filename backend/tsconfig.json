{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true,

    "types": ["node"],

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true
  }
}